# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed CORS origins (the frontend)
CORS_ORIGIN=http://localhost:3000

# ── Database (Supabase Postgres) ────────────────────────
DATABASE_URL=
DIRECT_URL=

# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic ───────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

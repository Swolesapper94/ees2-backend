# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed CORS origins (the frontend)
CORS_ORIGIN=http://localhost:3000

# ── Database (Supabase Postgres) ────────────────────────
# Get these from Supabase dashboard → Settings → Database:
# - Transaction pooler (port 6543) for DATABASE_URL
# - Direct connection (port 5432) for DIRECT_URL (used for migrations)
# Format: postgresql://postgres:PASSWORD@HOST:PORT/postgres?schema=public
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?schema=public
DIRECT_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?schema=public

# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.4-mini-2026-03-17

# ── Demo provider stubs ─────────────────────────────────
# These labels support controlled PM demos. Production must use NOT_CONFIGURED
# until real IPPS-A/Microsoft/photo/parser providers are implemented.
PERSONNEL_PROVIDER=IPPS_A_STUB
PROFILE_PHOTO_PROVIDER=MICROSOFT_365_STUB
SHOW_DEMO_SOURCE_LABELS=true
SUPPORT_FORM_PARSER_MODE=REAL
# Optional emergency fallback for the PM demo fixture; set to the SHA-256 of
# SGT_Davis_Demo_Support_Form.pdf when using SUPPORT_FORM_PARSER_MODE=DEMO_FIXTURE.
DEMO_SUPPORT_FORM_SHA256=a10a1a969569de704a728027f9f992b88cf78b604eb090c874bc497693d49b1b

# ── Goal tracking signals and reminders ─────────────────────
# These are informational process/evidence thresholds, never rating gates.
GOAL_REMINDER_DAYS=14
DOCUMENTATION_LOW_DENSITY_PER_MONTH=0.5
DOCUMENTATION_HIGH_DENSITY_PER_MONTH=1.5
LATE_CLUSTER_PERCENT=50
LATE_CLUSTER_DAYS=14
LOW_ARTIFACT_DENSITY_PERCENT=70

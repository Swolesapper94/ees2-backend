generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────

enum Rank {
  // Enlisted
  PVT // E1
  PV2 // E2
  PFC // E3
  SPC // E4
  CPL // E4
  SGT // E5 — DA 2166-9-1
  SSG // E6 — DA 2166-9-2
  SFC // E7 — DA 2166-9-2
  MSG // E8 — DA 2166-9-2
  FIRST_SERGEANT // E8 — DA 2166-9-2
  SGM // E9 — DA 2166-9-3
  CSM // E9 — DA 2166-9-3
  SMA // E9 special
  // Warrant Officers
  WO1
  CW2
  CW3
  CW4
  CW5
  // Officers
  SECOND_LT
  FIRST_LT
  CPT
  MAJ
  LTC
  COL
  BG
  MG
  LTG
  GEN
  GA // O11 — General of the Army (wartime only)
}

enum UserRole {
  SOLDIER // Can log support form entries, view own eval
  RATER // Writes Part III + Part IV rater sections
  SENIOR_RATER // Writes Part V senior rater section
  REVIEWER // Supplementary reviewer (when required)
  COMMANDER // Grants Commander's Access sidebar + dashboard (Section 20)
  ADMIN // Unit admin: manage users, chains, units
}

enum IdentitySourceSystem {
  NOT_CONFIGURED
  IPPS_A
  DEFENSE_MANPOWER
  DEVELOPMENT_SEED
}

enum IdentitySyncStatus {
  CURRENT
  STALE
  PENDING
  FAILED
  UNMATCHED
  NOT_CONFIGURED
}

enum ApplicationAccessStatus {
  ACTIVE
  SUSPENDED
  PENDING_REVIEW
  DISABLED
  LOCKED
}

enum AccessReviewStatus {
  CURRENT
  PENDING_REVIEW
  EXCEPTION_REVIEW
}

enum ApplicationSupportRole {
  NONE
  SUPPORT
  ADMINISTRATOR
}

enum IdentityExceptionType {
  DUPLICATE_IDENTITY
  UNMATCHED_AUTH_ACCOUNT
  MISSING_SOURCE_RECORD
  STALE_SOURCE_DATA
  UNIT_MAPPING_FAILURE
  IDENTIFIER_CONFLICT
  INVALID_ASSIGNMENT
  SYNC_FAILURE
  MANUAL_OVERRIDE_REVIEW
}

enum IdentityExceptionStatus {
  OPEN
  RESOLVED
  ESCALATED
}

enum AdministrativeScopeType {
  IDENTITY_ACCESS
  SERVICING_ADMINISTRATION
  BREAK_GLASS
}

enum SoldierCategory {
  OFFICER
  NCO
  WARRANT
  CIVILIAN
}

enum RatingAssignmentStatus {
  DRAFT
  APPROVED
  PUBLISHED
  SUPERSEDED
  CANCELLED
  QUARANTINED
}

enum RatingSchemeStatus {
  DRAFT
  IN_VALIDATION
  PENDING_APPROVAL
  RETURNED
  APPROVED
  PUBLISHED
  SUPERSEDED
  CANCELLED
}

enum RatingSchemeDelegationStatus {
  ACTIVE
  EXPIRED
  REVOKED
  SUSPENDED
}

enum RatingSchemeDelegationPermission {
  CREATE_DRAFT
  EDIT_DRAFT
  IMPORT_ASSIGNMENTS
  RESOLVE_VALIDATION
  SUBMIT_FOR_APPROVAL
  VIEW_AUDIT
}

enum BattalionCommandAssignmentStatus {
  ACTIVE
  ENDED
  SUSPENDED
}

enum EvalFormType {
  // ── NCOERs — Full builder in MVP ──────────────────────────────────
  NCOER_9_1 // DA 2166-9-1 — SGT (E5)            Binary scale
  NCOER_9_2 // DA 2166-9-2 — SSG–1SG/MSG (E6–E8) 4-level scale
  NCOER_9_3 // DA 2166-9-3 — CSM/SGM/SMA (E9)    4-level scale

  // ── OERs — Dashboard + support form only for MVP ──────────────────
  OER_67_10_1 // DA 67-10-1   — 2LT, 1LT
  OER_67_10_1A // DA 67-10-1A  — WO1, CW2
  OER_67_10_2 // DA 67-10-2   — CPT
  OER_67_10_2A // DA 67-10-2A  — CW3, CW4, CW5
  OER_67_10_3 // DA 67-10-3   — MAJ, LTC, COL
  OER_67_10_4 // DA 67-10-4   — BG and above
}

// ── RATING SCALES ─────────────────────────────────────────────────
// E5 (SGT) — DA 2166-9-1 — binary per attribute
enum RatingBinary {
  MET_STANDARD
  DID_NOT_MEET_STANDARD
}

// E6+ (SSG and above) — DA 2166-9-2 and 9-3 — 4-level per attribute
enum RatingFourLevel {
  NOT_MET_STANDARD
  QUALIFIED
  EXCEEDED_STANDARD
  FAR_EXCEEDED_STANDARD
}

// Senior Rater overall potential — all NCO forms
enum SeniorRaterRating {
  MOST_QUALIFIED
  HIGHLY_QUALIFIED
  QUALIFIED
  NOT_QUALIFIED
}

// ── EVALUATION STATUS ─────────────────────────────────────────────
enum EvalStatus {
  DRAFT // Eval created, rater hasn't started any section
  RATER_IN_PROGRESS // Rater has completed ≥1 section, still working
  PENDING_SENIOR_RATER // Rater done, SR working their section
  PENDING_SOLDIER_ACK // Awaiting rated soldier acknowledgment
  PENDING_SUPPLEMENTARY_REVIEW // Conditional — rater is 1LT only
  PENDING_FINAL_FORM_REVIEW // Rated Soldier verifies the populated PDF before completion
  COMPLETE // All required signatures collected
  SUBMITTED // Forwarded to HRC for official processing
  ACCEPTED // Terminal success — in official record
  RETURNED // Correction required
}

// ── SECTION KEYS ─────────────────────────────────────────────────
// Maps to Part IV sections on the NCOER and support form
enum SectionKey {
  CHARACTER // Army Values, Empathy, Warrior Ethos, Discipline
  PRESENCE // Bearing, Fitness, Confidence, Resilience
  INTELLECT // Mental Agility, Judgment, Innovation, Tact, Expertise
  LEADS // Leads Others, Trust, Influence, Example, Communicates
  DEVELOPS // Environment, Esprit, Prepares Self, Develops Others, Stewards
  ACHIEVES // Gets Results
  // Not a Part IV section — separate forms:
  RATER_OVERALL // Part IV rater overall performance comments
  SENIOR_RATER_OVERALL // Part V senior rater comments + box
  SOLDIER_COMMENTS // Rated soldier's acknowledgment comments
}

// ── SUPPORT FORM ENTRY TYPES ──────────────────────────────────────
// Matches actual DA 2166-9-1A Part V structure
enum EntryType {
  OBJECTIVE // "Indicate major performance objectives"
  ACCOMPLISHMENT // "List significant contributions and accomplishments"
}

enum GoalCategory {
  ROUTINE
  PROBLEM_SOLVING
  INNOVATIVE
  PERSONAL_DEVELOPMENT
  OTHER
}

enum GoalApprovalStatus {
  DRAFT
  PENDING_RATER_REVIEW
  APPROVED
  NEEDS_REVISION
}

enum GoalProgress {
  NOT_STARTED
  IN_PROGRESS
  ACHIEVED
  PARTIALLY_ACHIEVED
  NOT_ACHIEVED
}

enum FinalReviewOutcome {
  CONFIRMED
  DISPUTED
}

enum DisputeCategory {
  RATER_CONTENT
  SENIOR_RATER_CONTENT
}

// ── RATER CONFIRMATION ────────────────────────────────────────────
// Rater-owned review status for a soldier-logged entry. Distinct from the
// soldier's own flaggedByServiceMember disclosure on an artifact — this is
// the rater explicitly indicating they reviewed the entry and either trust
// it as context, want clarification, or are choosing not to rely on it.
// Confirming does NOT transform a self-uploaded artifact into an
// authoritative record — it only reflects rater review.
enum EntryConfirmationStatus {
  UNREVIEWED // Default — rater has not looked at this entry yet
  CONFIRMED // Rater reviewed and trusts this as usable context
  NEEDS_CLARIFICATION // Rater has a question — see clarificationNote
  NOT_USED // Rater reviewed but chose not to rely on this entry
}

enum SupportFormStatus {
  DRAFT
  INITIAL_COUNSELING_COMPLETE
  ACTIVE
  FINALIZED
  CONSUMED
  ARCHIVED
  QUARANTINED
}

enum EntryAuthorRole {
  RATED_SOLDIER
  RATER
  INTERMEDIATE_RATER
  SENIOR_RATER
  SERVICING_ADMIN
}

enum RecordDisposition {
  ACTIVE
  QUARANTINED
  ARCHIVED
}

enum SignatureStatus {
  NOT_REQUIRED
  PENDING
  SIGNED
  DECLINED
}

// ── SUPPORT FORM UPLOAD PIPELINE ──────────────────────────────────
enum SupportFormUploadStatus {
  PENDING_EXTRACT // File received, queued for Stage 1 vision
  EXTRACTING // Stage 1 in progress
  PENDING_PARSE // Stage 1 done, queued for Stage 2 parse
  PARSING // Stage 2 in progress
  PENDING_BULLETS // Stage 2 done, queued for Stage 3 generation
  GENERATING // Stage 3 in progress
  COMPLETE // All 3 stages done
  FAILED // Any stage errored
}

enum AIBulletStatus {
  PENDING_REVIEW // Not yet acted on by rater
  ACCEPTED // Copied as-is to final bullets
  EDITED // Modified before copying
  REJECTED // Dismissed
}

enum AIBulletConfidence {
  HIGH
  MEDIUM
  LOW
}

// ── SIGNATURE STALE REASON ────────────────────────────────────────
enum StaleReason {
  FIELD_EDIT // Content field changed post-signature
  ADMIN_CORRECTION // Admin-initiated correction
}

enum CounselingType {
  INITIAL // Within 30 days of rating period start (AR 623-3 requirement)
  QUARTERLY // Quarterly follow-up (AR 623-3 requirement)
}

// ── SUPPORT FORM ENTRY ARTIFACTS ──────────────────────────────────
// Proof soldiers attach to a support form entry: certificates, score
// sheets, photos, etc. Captioned once via OpenAI vision at upload time
// (see artifact-captioning.ts); the caption is reused as context for every
// bullet-generation call rather than re-sending images each time.
enum ArtifactType {
  CERTIFICATE // Award/certificate of completion, AER, school completion
  SCORE_SHEET // ACFT score sheet, range card, test result
  PHOTO // Photo of soldier performing a task, with team/squad, etc.
  DOCUMENT // Other paper record not covered above
  OTHER // Catch-all
}

enum ArtifactCaptionStatus {
  PENDING
  COMPLETE
  FAILED
}

// ─────────────────────────────────────────────────────────────────
// UNITS
// ─────────────────────────────────────────────────────────────────

model Unit {
  id        String   @id @default(cuid())
  name      String // e.g. "C Co, 1-505 PIR"
  uic       String?  @unique // Unit Identification Code
  parentId  String?
  parent    Unit?    @relation("UnitHierarchy", fields: [parentId], references: [id])
  children  Unit[]   @relation("UnitHierarchy")
  users     User[]
  ratingSchemeAssignments RatingSchemeAssignment[]
  ratingSchemes RatingScheme[] @relation("RatingSchemeUnit")
  approvalRatingSchemes RatingScheme[] @relation("RatingSchemeApprovalBattalion")
  ratingSchemeDelegations RatingSchemeDelegation[]
  commandAssignments BattalionCommandAssignment[]
  accessGrants Delegate[]
  administrativeScopes AdministrativeScope[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("units")
}

// ─────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(cuid())
  supabaseId        String     @unique
  email             String     @unique
  firstName         String
  lastName          String
  rank              Rank
  mos               String // e.g. "11B", "25U"
  roles             UserRole[]
  profilePictureUrl String? // URL to user's profile picture
  notificationPreferences Json? // per-NotificationCategory boolean overrides; a missing key defaults to enabled
  unitId            String?
  unit              Unit?      @relation(fields: [unitId], references: [id])
  dodid             String?    @unique // Future CAC integration
  lastLoginAt       DateTime?  // Updated when the authenticated user opens their dashboard
  category          SoldierCategory?
  applicationAccessStatus ApplicationAccessStatus @default(ACTIVE)
  accessReviewStatus AccessReviewStatus @default(CURRENT)
  applicationSupportRole ApplicationSupportRole @default(NONE)
  suspensionReason  String?
  suspendedAt       DateTime?
  suspendedByUserId String?
  breakGlassEligible Boolean @default(false)
  temporaryAdminExpiresAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  supportForms         SupportForm[]       @relation("SoldierSupportForms")
  raterOnChains        RatingChain[]       @relation("RaterChains")
  seniorRaterOnChains  RatingChain[]       @relation("SeniorRaterChains")
  reviewerOnChains     RatingChain[]       @relation("ReviewerChains")
  ratedOnChains        RatingChain[]       @relation("RatedSoldierChains")
  signatures           Signature[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  seniorRaterProfile   SeniorRaterProfile?
  authoredComments     EvalComment[]       @relation("AuthoredComments")
  delegateAppointments Delegate[]          @relation("DelegateAppointments")
  delegatedAccess      Delegate[]          @relation("DelegatedAccess")
  accessGrantsCreated  Delegate[]          @relation("AccessGrantGrantor")
  accessGrantsSubject  Delegate[]          @relation("AccessGrantSubject")
  uploadedForms        SupportFormUpload[] @relation("UploadedForms")
  ratedOnAssignments   RatingSchemeAssignment[] @relation("AssignmentRatedSoldier")
  raterOnAssignments   RatingSchemeAssignment[] @relation("AssignmentRater")
  intermediateRaterOnAssignments RatingSchemeAssignment[] @relation("AssignmentIntermediateRater")
  seniorRaterOnAssignments RatingSchemeAssignment[] @relation("AssignmentSeniorRater")
  supplementaryReviewerOnAssignments RatingSchemeAssignment[] @relation("AssignmentSupplementaryReviewer")
  createdAssignments   RatingSchemeAssignment[] @relation("AssignmentCreatedBy")
  approvedAssignments  RatingSchemeAssignment[] @relation("AssignmentApprovedBy")
  publishedAssignments RatingSchemeAssignment[] @relation("AssignmentPublishedBy")
  createdRatingSchemes RatingScheme[] @relation("RatingSchemeCreatedBy")
  submittedRatingSchemes RatingScheme[] @relation("RatingSchemeSubmittedBy")
  approvedRatingSchemes RatingScheme[] @relation("RatingSchemeApprovedBy")
  publishedRatingSchemes RatingScheme[] @relation("RatingSchemePublishedBy")
  returnedRatingSchemes RatingScheme[] @relation("RatingSchemeReturnedBy")
  commandedBattalions BattalionCommandAssignment[] @relation("BattalionCommander")
  grantedRatingSchemeDelegations RatingSchemeDelegation[] @relation("RatingSchemeDelegationCommander")
  receivedRatingSchemeDelegations RatingSchemeDelegation[] @relation("RatingSchemeDelegationDelegate")
  grantedRatingSchemeDelegationsBy RatingSchemeDelegation[] @relation("RatingSchemeDelegationGrantedBy")
  revokedRatingSchemeDelegations RatingSchemeDelegation[] @relation("RatingSchemeDelegationRevokedBy")
  supportEntriesCreated SupportFormEntry[] @relation("SupportEntryCreator")
  supportEntriesAssisted SupportFormEntry[] @relation("SupportEntrySubject")
  identitySourceRecord IdentitySourceRecord?
  identitySyncEvents IdentitySyncEvent[]
  identityExceptions IdentityException[]
  administrativeScopes AdministrativeScope[] @relation("AdministrativeScopeAdministrator")
  manualOverrides ManualOverride[]

  @@map("users")
}

model IdentitySourceRecord {
  id                  String               @id @default(cuid())
  userId              String               @unique
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSystem        IdentitySourceSystem @default(NOT_CONFIGURED)
  authoritativePersonId String?
  authoritativeEmail  String?
  dutyPosition        String?
  sourcePayload       Json?
  syncStatus          IdentitySyncStatus  @default(NOT_CONFIGURED)
  lastSynchronizedAt  DateTime?
  lastSyncAttemptAt   DateTime?
  syncError           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@map("identity_source_records")
}

model IdentitySyncEvent {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSystem   IdentitySourceSystem
  status         IdentitySyncStatus
  action         String
  details        Json?
  initiatedById  String?
  createdAt      DateTime           @default(now())

  @@index([userId, createdAt])
  @@map("identity_sync_events")
}

model IdentityException {
  id            String                  @id @default(cuid())
  userId        String?
  user          User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  type          IdentityExceptionType
  status        IdentityExceptionStatus @default(OPEN)
  severity      String                  @default("MEDIUM")
  summary       String
  details       Json?
  resolvedAt    DateTime?
  resolvedById  String?
  resolutionNote String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([status, type])
  @@index([userId, status])
  @@map("identity_exceptions")
}

model AdministrativeScope {
  id               String                  @id @default(cuid())
  administratorId  String
  administrator    User                    @relation("AdministrativeScopeAdministrator", fields: [administratorId], references: [id], onDelete: Cascade)
  unitId           String?
  unit             Unit?                   @relation(fields: [unitId], references: [id], onDelete: SetNull)
  scopeType        AdministrativeScopeType @default(IDENTITY_ACCESS)
  expiresAt        DateTime?
  createdById      String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([administratorId, scopeType])
  @@map("administrative_scopes")
}

model ManualOverride {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  field         String
  value         Json?
  reason        String
  expiresAt     DateTime?
  createdById   String
  reviewedAt    DateTime?
  reviewedById  String?
  createdAt     DateTime @default(now())

  @@index([userId, expiresAt])
  @@map("manual_overrides")
}

// ─────────────────────────────────────────────────────────────────
// RATING CHAINS
// ─────────────────────────────────────────────────────────────────

// ── EVAL CATEGORY ─────────────────────────────────────────────────
// Broad NCO vs Officer split — derived from resolveFormType(rank).
// Distinct from EvalFormType (the specific grade-plate form, e.g. NCOER_9_2).
enum EvalCategory {
  NCOER
  OER
}

// Versioned, effective-dated rating scheme. RatingChain remains temporarily
// while live records are migrated; new compliance-sensitive code should target
// this model and the immutable evaluation snapshot below.
model RatingSchemeAssignment {
  id                       String                 @id @default(cuid())
  ratingSchemeId           String?
  ratedSoldierId           String
  raterId                  String
  intermediateRaterId      String?
  seniorRaterId            String
  supplementaryReviewerId  String?
  unitId                   String?
  formCategory             EvalCategory
  effectiveFrom            DateTime
  effectiveTo              DateTime?
  status                   RatingAssignmentStatus @default(DRAFT)
  requiresSupplementaryReview Boolean             @default(false)
  changeReason             String?
  exceptionToPolicyId      String?
  supersedesAssignmentId   String?
  approvedByUserId         String?
  approvedAt               DateTime?
  publishedByUserId        String?
  publishedAt              DateTime?
  createdByUserId          String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  ratedSoldier          User  @relation("AssignmentRatedSoldier", fields: [ratedSoldierId], references: [id])
  rater                 User  @relation("AssignmentRater", fields: [raterId], references: [id])
  intermediateRater     User? @relation("AssignmentIntermediateRater", fields: [intermediateRaterId], references: [id])
  seniorRater           User  @relation("AssignmentSeniorRater", fields: [seniorRaterId], references: [id])
  supplementaryReviewer User? @relation("AssignmentSupplementaryReviewer", fields: [supplementaryReviewerId], references: [id])
  createdBy             User? @relation("AssignmentCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy            User? @relation("AssignmentApprovedBy", fields: [approvedByUserId], references: [id])
  publishedBy           User? @relation("AssignmentPublishedBy", fields: [publishedByUserId], references: [id])
  ratingScheme          RatingScheme? @relation(fields: [ratingSchemeId], references: [id], onDelete: SetNull)
  unit                  Unit? @relation(fields: [unitId], references: [id])
  supersedes            RatingSchemeAssignment? @relation("AssignmentSupersession", fields: [supersedesAssignmentId], references: [id])
  replacements          RatingSchemeAssignment[] @relation("AssignmentSupersession")
  evaluations           EvaluationRatingSnapshot[]
  supportForms          SupportForm[]
  accessGrants          Delegate[]

  @@index([ratedSoldierId, status, effectiveFrom])
  @@index([status, effectiveFrom])
  @@index([ratingSchemeId, effectiveFrom])
  @@map("rating_scheme_assignments")
}

model BattalionCommandAssignment {
  id          String                            @id @default(cuid())
  battalionId String
  commanderUserId String
  status      BattalionCommandAssignmentStatus  @default(ACTIVE)
  effectiveFrom DateTime
  effectiveTo DateTime?
  battalion   Unit                              @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  commander   User                              @relation("BattalionCommander", fields: [commanderUserId], references: [id], onDelete: Cascade)
  createdAt   DateTime                          @default(now())
  updatedAt   DateTime                          @updatedAt

  @@index([battalionId, status, effectiveFrom])
  @@index([commanderUserId, status])
  @@map("battalion_command_assignments")
}

model RatingScheme {
  id          String             @id @default(cuid())
  unitId      String
  battalionId String
  version     Int
  status      RatingSchemeStatus @default(DRAFT)
  effectiveFrom DateTime
  effectiveTo DateTime?
  createdByUserId String
  submittedByUserId String?
  submittedAt DateTime?
  approvedByUserId String?
  approvedAt DateTime?
  approvalAuthorityPositionId String?
  approvalComments String?
  publishedByUserId String?
  publishedAt DateTime?
  returnedByUserId String?
  returnedAt DateTime?
  returnComments String?
  changeReason String?
  previousSchemeId String?
  versionHash String?
  unit        Unit               @relation("RatingSchemeUnit", fields: [unitId], references: [id], onDelete: Cascade)
  battalion   Unit               @relation("RatingSchemeApprovalBattalion", fields: [battalionId], references: [id], onDelete: Cascade)
  createdBy   User               @relation("RatingSchemeCreatedBy", fields: [createdByUserId], references: [id])
  submittedBy User?              @relation("RatingSchemeSubmittedBy", fields: [submittedByUserId], references: [id])
  approvedBy User?               @relation("RatingSchemeApprovedBy", fields: [approvedByUserId], references: [id])
  publishedBy User?              @relation("RatingSchemePublishedBy", fields: [publishedByUserId], references: [id])
  returnedBy User?               @relation("RatingSchemeReturnedBy", fields: [returnedByUserId], references: [id])
  previousScheme RatingScheme?   @relation("RatingSchemeSupersession", fields: [previousSchemeId], references: [id])
  replacements RatingScheme[]    @relation("RatingSchemeSupersession")
  assignments RatingSchemeAssignment[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([unitId, version])
  @@index([unitId, status, effectiveFrom])
  @@index([battalionId, status, effectiveFrom])
  @@map("rating_schemes")
}

model RatingSchemeDelegation {
  id          String                         @id @default(cuid())
  battalionId String
  commanderUserId String
  delegateUserId String
  effectiveFrom DateTime
  effectiveTo DateTime?
  status      RatingSchemeDelegationStatus  @default(ACTIVE)
  permissions RatingSchemeDelegationPermission[]
  grantedByUserId String
  grantedAt   DateTime                      @default(now())
  revokedByUserId String?
  revokedAt   DateTime?
  battalion   Unit                           @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  commander   User                           @relation("RatingSchemeDelegationCommander", fields: [commanderUserId], references: [id], onDelete: Cascade)
  delegate    User                           @relation("RatingSchemeDelegationDelegate", fields: [delegateUserId], references: [id], onDelete: Cascade)
  grantedBy   User                           @relation("RatingSchemeDelegationGrantedBy", fields: [grantedByUserId], references: [id])
  revokedBy   User?                          @relation("RatingSchemeDelegationRevokedBy", fields: [revokedByUserId], references: [id])
  createdAt   DateTime                       @default(now())
  updatedAt   DateTime                       @updatedAt

  @@index([battalionId, delegateUserId, status])
  @@index([commanderUserId, status])
  @@map("rating_scheme_delegations")
}

// Captures the exact officials and grades governing an evaluation at creation.
// The application never updates snapshots; future assignment changes apply
// only to future evaluations.
model EvaluationRatingSnapshot {
  id                       String                  @id @default(cuid())
  evaluationId             String                  @unique
  ratingSchemeAssignmentId String
  ratedSoldierId           String
  raterId                  String
  intermediateRaterId      String?
  seniorRaterId            String
  supplementaryReviewerId  String?
  ratedRank                Rank
  ratedCategory            SoldierCategory
  raterRank                Rank
  raterCategory            SoldierCategory
  seniorRaterRank          Rank
  seniorRaterCategory      SoldierCategory
  formCategory             EvalCategory
  ratedGrade               String
  exceptionToPolicyId      String?
  createdAt                DateTime                @default(now())

  evaluation               Evaluation              @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  ratingSchemeAssignment   RatingSchemeAssignment  @relation(fields: [ratingSchemeAssignmentId], references: [id])

  @@index([ratingSchemeAssignmentId])
  @@map("evaluation_rating_snapshots")
}

model RatingChain {
  id             String    @id @default(cuid())
  ratedSoldierId String
  raterId        String
  seniorRaterId  String
  reviewerId     String? // Required per AR 623-3 for certain grades
  effectiveDate  DateTime
  endDate        DateTime?
  isActive       Boolean   @default(true)

  ratedSoldier       User                @relation("RatedSoldierChains", fields: [ratedSoldierId], references: [id])
  rater              User                @relation("RaterChains", fields: [raterId], references: [id])
  seniorRater        User                @relation("SeniorRaterChains", fields: [seniorRaterId], references: [id])
  reviewer           User?               @relation("ReviewerChains", fields: [reviewerId], references: [id])
  evaluations        Evaluation[]
  counselingSessions CounselingSession[]
  supportForms       SupportForm[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@map("rating_chains")
}

// ─────────────────────────────────────────────────────────────────
// COUNSELING SESSIONS
// AR 623-3 requires: initial counseling within 30 days of period start,
// plus quarterly follow-up counseling. This table tracks compliance.
// ─────────────────────────────────────────────────────────────────

model CounselingSession {
  id              String         @id @default(cuid())
  ratingChainId   String
  ratingChain     RatingChain    @relation(fields: [ratingChainId], references: [id])
  type            CounselingType
  sessionDate     DateTime
  notes           String?
  raterInitials   String?
  soldierInitials String?
  goalDiscussions GoalCounselingDiscussion[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("counseling_sessions")
}

// ─────────────────────────────────────────────────────────────────
// SUPPORT FORMS
// ─────────────────────────────────────────────────────────────────

model SupportForm {
  id                String             @id @default(cuid())
  soldierId         String
  soldier           User               @relation("SoldierSupportForms", fields: [soldierId], references: [id])
  // Anchors this support form to a specific rater/SR assignment rather than an
  // implicit "current period" string. A RatingChain can outlive multiple annual
  // cycles, so uniqueness is enforced at the app layer (see completeness.ts /
  // support-forms.ts POST handler): at most one support form per chain that is
  // NOT yet "consumed" by an Evaluation (Evaluation.supportFormId links them).
  // Nullable for safe migration of existing seeded rows; new rows always set it.
  ratingChainId     String?
  ratingChain       RatingChain?       @relation(fields: [ratingChainId], references: [id])
  ratingSchemeAssignmentId String?
  ratingSchemeAssignment RatingSchemeAssignment? @relation(fields: [ratingSchemeAssignmentId], references: [id])
  // Snapshot of resolveFormType(soldier.rank).evalType at creation time.
  // Decides which Part I/III admin fields apply and which PDF layout renders.
  // Nullable at the DB layer only to keep this migration additive/non-breaking
  // against existing seeded rows; every new row sets it (enforced by Zod in
  // the POST route, not left as an app-level "maybe" the way the field name
  // might suggest).
  evalCategory      EvalCategory?
  ratingPeriodStart DateTime
  ratingPeriodEnd   DateTime?
  dutyTitle         String
  // Nullable: NCO forms require it (validated in the route), Officer forms
  // don't carry a MOSC field at all — Part III is a single narrative field.
  dutyMosc          String?
  dailyDutiesScope  String?
  areasOfEmphasis   String?
  appointedDuties   String?
  // Part I — SSD/NCOES requirement met for next grade (NCO forms only)
  ssdNcoesMet       Boolean?
  // Part IV: Soldier's own goals and expectations for the period
  soldierGoals      String?
  raterContextNote  String?
  raterContextNoteSetById String?
  raterContextNoteSetAt DateTime?
  isActive          Boolean            @default(true)
  status            SupportFormStatus  @default(DRAFT)
  disposition       RecordDisposition  @default(ACTIVE)
  initiatedByUserId String?
  initialCounselingDate DateTime?
  finalizedAt       DateTime?
  consumedByEvaluationId String?
  consumedAt        DateTime?
  version           Int                @default(1)
  parentFormId      String?
  // Set when the guided flow's Finalize step passes the hard-gate completeness
  // check. Presence of this timestamp is what unlocks eval initiation.
  completedAt       DateTime?
  entries           SupportFormEntry[]
  goals             Goal[]
  evaluations       Evaluation[]
  accessGrants      Delegate[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("support_forms")
}

model SupportFormEntry {
  id            String      @id @default(cuid())
  supportFormId String
  supportForm   SupportForm @relation(fields: [supportFormId], references: [id])
  entryDate     DateTime    @default(now())

  // Maps to Part V of DA 2166-9-1A
  // Each section has both objectives and accomplishments
  section   SectionKey // CHARACTER | PRESENCE | INTELLECT | LEADS | DEVELOPS | ACHIEVES
  entryType EntryType // OBJECTIVE | ACCOMPLISHMENT

  rawText       String // What the soldier or rater wrote
  createdByUserId      String?
  authorRoleAtCreation EntryAuthorRole?
  lastEditedByUserId   String?
  onBehalfOfUserId     String?
  delegationGrantId    String?
  createdByUser        User? @relation("SupportEntryCreator", fields: [createdByUserId], references: [id])
  assistedUser         User? @relation("SupportEntrySubject", fields: [onBehalfOfUserId], references: [id])
  lockedAt             DateTime?
  lockReason           String?
  sourceVersion        Int @default(1)
  tags          String[] // Free-form tags for filtering
  isHighlight   Boolean   @default(false) // Flagged as strongest entry for this period
  counseled     Boolean   @default(false) // Was this discussed in a counseling session?
  counseledDate DateTime?

  // AI usage tracking
  usedInEvalId String? // Which eval used this entry, if any

  // Rater confirmation (5.4) — rater-owned review status, timestamped + attributed
  confirmationStatus EntryConfirmationStatus @default(UNREVIEWED)
  confirmedById      String?
  confirmedAt        DateTime?
  clarificationNote  String? // Short note when status = NEEDS_CLARIFICATION

  artifacts SupportFormEntryArtifact[]
  goalLinks GoalEntryLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("support_form_entries")
}

model Goal {
  id                   String             @id @default(cuid())
  supportFormId        String
  supportForm          SupportForm        @relation(fields: [supportFormId], references: [id], onDelete: Cascade)
  sectionKey           SectionKey
  title                String
  description          String
  category             GoalCategory?
  targetDate           DateTime?
  createdById          String
  createdByRole        EntryAuthorRole
  lastEditedById       String?
  lastEditedAt         DateTime?
  approvalStatus       GoalApprovalStatus @default(DRAFT)
  approvedByRaterId    String?
  approvedAt           DateTime?
  revisionNote         String?
  establishedAtCounselingSessionId String?
  soldierAssessment    GoalProgress?
  soldierAssessmentNote String?
  soldierAssessmentAt  DateTime?
  raterAssessment      GoalProgress?
  raterAssessmentById  String?
  raterAssessmentNote  String?
  raterAssessmentAt    DateTime?
  carriedForwardFromGoalId String?
  carriedForwardFromGoal Goal? @relation("GoalCarryForward", fields: [carriedForwardFromGoalId], references: [id])
  carriedForwardGoals  Goal[]  @relation("GoalCarryForward")
  linkedEntries        GoalEntryLink[]
  counselingDiscussions GoalCounselingDiscussion[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([supportFormId, sectionKey])
  @@map("goals")
}

model GoalEntryLink {
  id                 String           @id @default(cuid())
  goalId             String
  goal               Goal             @relation(fields: [goalId], references: [id], onDelete: Cascade)
  supportFormEntryId String
  supportFormEntry   SupportFormEntry @relation(fields: [supportFormEntryId], references: [id], onDelete: Cascade)
  linkedById         String
  linkedByRole       EntryAuthorRole
  linkedAt           DateTime         @default(now())

  @@unique([goalId, supportFormEntryId])
  @@map("goal_entry_links")
}

model GoalCounselingDiscussion {
  id                  String            @id @default(cuid())
  goalId              String
  goal                Goal              @relation(fields: [goalId], references: [id], onDelete: Cascade)
  counselingSessionId String
  counselingSession   CounselingSession @relation(fields: [counselingSessionId], references: [id], onDelete: Cascade)
  note                String?
  percentAchieved     Int?
  setById             String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([goalId, counselingSessionId])
  @@map("goal_counseling_discussions")
}

// Proof attached to a SupportFormEntry — see ArtifactType above.
model SupportFormEntryArtifact {
  id      String           @id @default(cuid())
  entryId String
  entry   SupportFormEntry @relation(fields: [entryId], references: [id])
  createdByUserId      String?
  lastEditedByUserId   String?
  onBehalfOfUserId     String?
  delegationGrantId    String?

  type     ArtifactType
  fileUrl  String // Supabase Storage URL
  fileType String // "image" | "pdf"

  // Populated by generateArtifactCaption() — a short factual description of
  // what the artifact shows/proves, fed into bullet-generation prompts.
  aiCaption       String?
  aiCaptionStatus ArtifactCaptionStatus @default(PENDING)
  aiCaptionError  String?

  // Soldier self-attestation. We do not have an automated iPERMS integration
  // (external DoD system, no public API available) — this is the practical
  // substitute: the soldier acknowledges the document may not yet be
  // reflected in iPERMS or flags a discrepancy, which surfaces to the
  // rater/senior rater as a visible flag rather than a silent claim.
  flaggedByServiceMember Boolean @default(false)
  flagNote               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("support_form_entry_artifacts")
}

// ─────────────────────────────────────────────────────────────────
// EVALUATIONS (NCOERs)
// ─────────────────────────────────────────────────────────────────

model Evaluation {
  id                          String       @id @default(cuid())
  ratingChainId               String
  ratingChain                 RatingChain  @relation(fields: [ratingChainId], references: [id])
  supportFormId               String?
  supportForm                 SupportForm? @relation(fields: [supportFormId], references: [id])
  ratingSnapshot              EvaluationRatingSnapshot?
  finalFormReviews            FinalFormReview[]
  formType                    EvalFormType
  status                      EvalStatus   @default(DRAFT)
  disposition                 RecordDisposition @default(ACTIVE)
  // Supplementary review (Section 2) — set true at creation when rater.rank === FIRST_LT
  requiresSupplementaryReview Boolean      @default(false)

  // Part I — Administrative Data (exact DA form field names)
  periodStart         DateTime
  periodEnd           DateTime
  ratedMonths         Int
  nonRatedMonths      Int      @default(0)
  nonRatedCodes       String?
  reasonForSubmission String // Annual, Change of Rater, Relief for Cause, etc.
  statusCode          String? // e.g. "00" Active Duty
  numberOfEnclosures  Int      @default(0)

  // Part III — Duty Description (rater completes)
  principalDutyTitle     String?
  dutyMosc               String?
  dailyDutiesScope       String? // People, equipment, facilities, dollars
  areasOfSpecialEmphasis String?
  appointedDuties        String?

  // Part V — Senior Rater succession planning
  // AR 623-3: two successive assignments + one broadening (3-5 years)
  successiveAssignment1 String?
  successiveAssignment2 String?
  broadeningAssignment  String?

  // Senior rater overall
  seniorRaterRating SeniorRaterRating?

  // APFT/ACFT data (Part IVa/IVb on DA 2166-9-1)
  acftPassFail         String? // "Pass" | "Fail" | "Profile"
  acftDate             DateTime?
  heightInches         Int?
  weightLbs            Int?
  withinWeightStandard Boolean?

  // HRC processing timestamps — set by route handlers on status transitions
  submittedAt DateTime? // Set when status → SUBMITTED
  acceptedAt  DateTime? // Set when status → ACCEPTED

  sections            EvalSection[]
  signatures          Signature[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  milestones          EvalMilestone[]
  comments            EvalComment[]
  supportFormUploads  SupportFormUpload[]
  aiBulletSuggestions AIBulletSuggestion[]
  returns             EvaluationReturn[]
  accessGrants        Delegate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("evaluations")
}

// ─────────────────────────────────────────────────────────────────
// EVALUATION RETURNS — tracks each HRC rejection with reason
// Multiple returns possible per eval (count distinct evals for rate)
// ─────────────────────────────────────────────────────────────────

enum ReturnReason {
  ADMIN_ERROR // Incorrect dates, missing data, wrong form
  PROHIBITED_LANGUAGE // Superlatives, prohibited references
  MISSING_SIGNATURE // Out-of-sequence or absent signatures
  RATING_PERIOD_ERROR // Overlap, wrong order, assignment mismatch
  OTHER // Catch-all for unlisted reasons
}

model EvaluationReturn {
  id           String       @id @default(cuid())
  evaluationId String
  evaluation   Evaluation   @relation(fields: [evaluationId], references: [id])
  returnReason ReturnReason
  returnedAt   DateTime     @default(now())
  notes        String? // Free-text notes about the specific return
  resolvedAt   DateTime? // When the correction was resubmitted
  createdAt    DateTime     @default(now())

  @@map("evaluation_returns")
}

// ─────────────────────────────────────────────────────────────────
// EVALUATION SECTIONS
// One row per section per evaluation.
// Rating field used depends on formType:
//   - NCOER_9_1 → ratingBinary
//   - NCOER_9_2 / NCOER_9_3 → ratingFourLevel
// ─────────────────────────────────────────────────────────────────

model EvalSection {
  id           String     @id @default(cuid())
  evaluationId String
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id])
  section      SectionKey

  // Rating box — only one is used per form type
  ratingBinary    RatingBinary? // E5 (SGT) forms only
  ratingFourLevel RatingFourLevel? // E6+ forms only

  // Bullet pipeline
  // stagingBullets = AI suggestions in the staging panel (not yet on the form)
  // finalBullets   = bullets accepted and moved onto the form
  stagingBullets String[] @default([])
  finalBullets   String[] @default([])

  // Anti-autopilot tracking
  // Tracks which final bullets originated from AI vs. were human-written
  bulletSources Json?
  // e.g. { "0": "AI_MODIFIED", "1": "HUMAN", "2": "AI_UNMODIFIED" }
  // "AI_UNMODIFIED" triggers the soft-gate prompt before submission

  // Provenance chain (MVP audit 5.9): final bullet index -> originating
  // AIBulletSuggestion.id + its sourceEntryIds + its immutable sourceSnapshot.
  // Only set for AI-sourced bullets (HUMAN bullets have no entry here).
  // e.g. { "2": { "suggestionId": "...", "sourceEntryIds": [...], "sourceSnapshot": [...] } }
  bulletProvenance Json?

  isComplete    Boolean   @default(false)
  completedAt   DateTime?
  completedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([evaluationId, section])
  @@map("eval_sections")
}

// ─────────────────────────────────────────────────────────────────
// SENIOR RATER PROFILE
// Tracks how many evals the SR has rated by grade and rating level.
// Enforces the MQ% constraint — live profile meter in the UI.
// ─────────────────────────────────────────────────────────────────

model SeniorRaterProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Counts by grade (JSON for flexibility across form types)
  // e.g. { "SGT": { "MQ": 2, "HQ": 5, "Q": 3, "NQ": 0 } }
  profileData Json     @default("{}")
  lastUpdated DateTime @default(now())

  @@map("senior_rater_profiles")
}

model FinalFormReview {
  id              String             @id @default(cuid())
  evaluationId    String
  evaluation      Evaluation         @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  reviewedBy      String
  outcome         FinalReviewOutcome
  contentHash     String
  disputeCategory DisputeCategory?
  disputeReason   String?
  reviewedAt      DateTime           @default(now())
  supersededAt    DateTime?

  @@index([evaluationId, reviewedAt])
  @@map("final_form_reviews")
}

// ─────────────────────────────────────────────────────────────────
// SIGNATURES
// All parties are notified simultaneously (parallel, not sequential).
// Status visible to everyone in the chain.
// ─────────────────────────────────────────────────────────────────

model Signature {
  id            String          @id @default(cuid())
  evaluationId  String
  evaluation    Evaluation      @relation(fields: [evaluationId], references: [id])
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  role          UserRole
  status        SignatureStatus @default(PENDING)
  signedAt      DateTime?
  declineReason String?
  notifiedAt    DateTime?

  // Consent mechanism (Section 10)
  nameConfirmation String? // User types their own name to confirm
  ipAddress        String? // Captured server-side at signing
  userAgent        String? // Browser info

  // Future CAC/PKI (stubbed — not implemented for MVP)
  cacCertSerial String?
  pkiTokenHash  String?

  // Content hash — SHA-256 of the fields in signing scope at time of signature
  // Used to detect if content changed after signing (§6)
  contentHash    String?
  isStale        Boolean      @default(false)
  staledAt       DateTime?
  staledByUserId String?
  staledReason   StaleReason?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([evaluationId, role])
  @@map("signatures")
}

// ─────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────

enum NotificationCategory {
  EVAL_LIFECYCLE // Status changes, signature requests, routing events
  MILESTONE // AR 623-3 suspense events (overdue, due soon)
  COLLABORATION // Comment threads, informal review requests
  DELEGATE // Delegate appointed, revoked, or reminded
  SYSTEM // Global announcements (maintenance, doctrine updates, new features)
}

model Notification {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id])
  evaluationId String?
  evaluation   Evaluation?          @relation(fields: [evaluationId], references: [id])
  category     NotificationCategory @default(SYSTEM)
  title        String
  message      String
  actionUrl    String? // Route to navigate when user clicks action button
  actionLabel  String? // e.g. "View Eval", "Sign Now", "View Comment"
  isDismissed  Boolean              @default(false)
  readAt       DateTime?
  createdAt    DateTime             @default(now())

  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────
// AUDIT LOG — immutable, never delete rows
// ─────────────────────────────────────────────────────────────────

model AuditLog {
  id           String      @id @default(cuid())
  evaluationId String?
  evaluation   Evaluation? @relation(fields: [evaluationId], references: [id])
  actorId      String
  actor        User        @relation(fields: [actorId], references: [id])
  action       String
  // Examples: SECTION_RATED | BULLET_ACCEPTED | BULLET_AI_UNMODIFIED_OVERRIDE
  //           SIGNATURE_APPLIED | SIGNATURE_DECLINED | CONSISTENCY_CHECK_OVERRIDDEN
  //           SR_PROFILE_MQ_WARNING_ACKNOWLEDGED
  entityType   String
  entityId     String
  metadata     Json?
  subjectUserId       String?
  delegationGrantId   String?
  delegationCapability DelegationCapability?
  requestId           String?
  ipAddress           String?
  userAgent           String?
  createdAt    DateTime    @default(now())

  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────
// MILESTONES & SUSPENSE TRACKING (Section 4)
// AR 623-3 counseling + section due dates. Auto-generated on eval create.
// ─────────────────────────────────────────────────────────────────

enum MilestoneType {
  INITIAL_COUNSELING_DUE // AR 623-3: within 30 days of period start
  QUARTERLY_COUNSELING_1 // ~90 days
  QUARTERLY_COUNSELING_2 // ~180 days
  QUARTERLY_COUNSELING_3 // ~270 days
  RATER_SECTION_DUE // Default: 14 days before period end
  SENIOR_RATER_DUE // Default: 7 days before period end
  SOLDIER_ACK_DUE // Default: 3 days before period end
  EVAL_SUBMISSION_DUE // Hard deadline: period end date
}

enum MilestoneStatus {
  UPCOMING
  DUE_SOON // Within 7 days
  OVERDUE // Past due, not complete
  COMPLETE
  WAIVED // Admin override with reason
}

model EvalMilestone {
  id           String          @id @default(cuid())
  evaluationId String
  evaluation   Evaluation      @relation(fields: [evaluationId], references: [id])
  type         MilestoneType
  status       MilestoneStatus @default(UPCOMING)
  dueDate      DateTime
  completedAt  DateTime?
  waivedAt     DateTime?
  waivedById   String?
  waivedReason String?
  notifiedAt   DateTime?
  escalatedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([evaluationId, type])
  @@map("eval_milestones")
}

// ─────────────────────────────────────────────────────────────────
// DRAFT COLLABORATION & IN-SYSTEM REVIEW (Section 6)
// Informal feedback exchanged inside the system before formal routing.
// ─────────────────────────────────────────────────────────────────

enum CommentStatus {
  OPEN
  RESOLVED
  ACKNOWLEDGED
}

model EvalComment {
  id           String        @id @default(cuid())
  evaluationId String
  evaluation   Evaluation    @relation(fields: [evaluationId], references: [id])
  sectionKey   SectionKey? // null = general comment on the whole eval
  authorId     String
  author       User          @relation("AuthoredComments", fields: [authorId], references: [id])
  createdByUserId       String?
  lastEditedByUserId    String?
  onBehalfOfUserId      String?
  delegationGrantId     String?
  content      String
  status       CommentStatus @default(OPEN)
  resolvedById String?
  resolvedAt   DateTime?
  parentId     String?
  parent       EvalComment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies      EvalComment[] @relation("CommentThread")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("eval_comments")
}

// ─────────────────────────────────────────────────────────────────
// DELEGATE SYSTEM (Section 19)
// A user appoints a delegate who gets visibility (not write access) into
// their eval status. Useful when the principal is deployed or TDY.
// ─────────────────────────────────────────────────────────────────

enum DelegateAccessLevel {
  VIEW_ONLY // Can see eval status, support form summary, rating scheme
  PUSH_ALONG // VIEW_ONLY + can send reminder notifications to chain members
}

enum DelegationType {
  PERSONAL_ASSISTANT
  RATING_OFFICIAL_ASSISTANT
  SERVICING_ADMIN_ASSIGNMENT
}

enum DelegationStatus {
  PENDING
  ACTIVE
  DECLINED
  EXPIRED
  REVOKED
  SUSPENDED
}

enum DelegationCapability {
  VIEW_WORKFLOW_STATUS
  VIEW_ADMINISTRATIVE_DATA
  VIEW_SUPPORT_FORM
  VIEW_PERMITTED_EVALUATION_DATA
  ADD_DRAFT_SUPPORT_ENTRY
  EDIT_OWN_DRAFT_SUPPORT_ENTRY
  UPLOAD_ARTIFACT
  ORGANIZE_ARTIFACT
  COMPLETE_ADMINISTRATIVE_FIELD
  RESPOND_TO_ADMIN_RETURN
  REQUEST_SOLDIER_REVIEW
  REQUEST_RATER_REVIEW
  SEND_WORKFLOW_REMINDER
  DOWNLOAD_WORKING_COPY
  ADD_NON_EVALUATIVE_COMMENT
}

model Delegate {
  id              String              @id @default(cuid())
  principalId     String // The user who appointed the delegate
  principal       User                @relation("DelegateAppointments", fields: [principalId], references: [id])
  delegateUserId  String // The user who is the delegate
  delegateUser    User                @relation("DelegatedAccess", fields: [delegateUserId], references: [id])
  accessLevel     DelegateAccessLevel @default(VIEW_ONLY)
  effectiveDate   DateTime
  expiryDate      DateTime? // Delegate access can be time-limited
  isActive        Boolean             @default(true)
  appointedReason String? // "Deployed to CENTCOM AOR 01 JUN 2025"
  // Additive access-grant fields. Legacy principal/delegate columns remain
  // authoritative until the compatibility migration maps each record.
  grantorUserId         String?
  subjectUserId         String?
  delegationType        DelegationType?
  status                DelegationStatus @default(PENDING)
  effectiveFrom         DateTime?
  effectiveTo           DateTime?
  evaluationId          String?
  supportFormId         String?
  ratingAssignmentId    String?
  unitId                String?
  justification         String?
  requiresReview        Boolean @default(false)
  createdByUserId       String?
  approvedByUserId      String?
  acceptedAt            DateTime?
  revokedAt             DateTime?
  revokedByUserId       String?
  revocationReason      String?
  grantor               User? @relation("AccessGrantGrantor", fields: [grantorUserId], references: [id])
  subject               User? @relation("AccessGrantSubject", fields: [subjectUserId], references: [id])
  evaluation            Evaluation? @relation(fields: [evaluationId], references: [id])
  supportForm           SupportForm? @relation(fields: [supportFormId], references: [id])
  ratingAssignment      RatingSchemeAssignment? @relation(fields: [ratingAssignmentId], references: [id])
  unit                  Unit? @relation(fields: [unitId], references: [id])
  capabilities          DelegationCapabilityGrant[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([principalId, delegateUserId])
  @@map("delegates")
}

model DelegationCapabilityGrant {
  id                String                 @id @default(cuid())
  delegationGrantId String
  capability        DelegationCapability
  delegationGrant   Delegate               @relation(fields: [delegationGrantId], references: [id], onDelete: Cascade)

  @@unique([delegationGrantId, capability])
  @@map("delegation_capability_grants")
}

// ─────────────────────────────────────────────────────────────────
// REGULATION KNOWLEDGE BASE — vector embeddings for RAG support bot
// ─────────────────────────────────────────────────────────────────

model RegulationChunk {
  id        String   @id @default(cuid())
  docTitle  String // "DA PAM 623-3", "AR 623-3", "AR 350-1"
  section   String // "Chapter 3", "Table 3-1", "Appendix B"
  heading   String // Human-readable heading e.g. "NCOER Bullet Comments"
  content   String // The actual text chunk (~400-800 words)
  // Embedding stored via pgvector. Declared `Unsupported` (not a real column
  // Prisma Client can read/write directly — raw SQL via $queryRawUnsafe is
  // still required for it) SPECIFICALLY so `prisma migrate dev`'s schema
  // diff sees it and stops trying to DROP it as an "unknown" column. This
  // field was accidentally dropped twice already (2026-07-01 UserRole enum
  // migration, then again by an unrelated 2026-07-05 migration) because it
  // was previously absent from schema.prisma entirely — do NOT remove this
  // field or migrate dev will drop the column a third time.
  embedding Unsupported("vector(1536)")?
  pageStart Int? // PDF page number (for citation)
  pageEnd   Int?
  createdAt DateTime @default(now())

  @@index([docTitle, section])
  @@map("regulation_chunks")
}

// ─────────────────────────────────────────────────────────────────
// SUPPORT FORM UPLOAD PIPELINE (Phase 1 — §3 of EES2-AGENT-INSTRUCTIONS)
// DA 2166-9-1A uploaded by soldier → OpenAI vision extract → parse
// → AI bullet suggestions for rater only (soldier never sees).
// ─────────────────────────────────────────────────────────────────

model SupportFormUpload {
  id           String                  @id @default(cuid())
  evaluationId String
  evaluation   Evaluation              @relation(fields: [evaluationId], references: [id])
  uploadedById String
  uploadedBy   User                    @relation("UploadedForms", fields: [uploadedById], references: [id])
  fileUrl      String // Supabase Storage URL
  fileType     String // "pdf" | "image"
  parseStatus  SupportFormUploadStatus @default(PENDING_EXTRACT)
  parseError   String?
  rawExtract   String? // Stage 1 raw vision output
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  extractedEntries  AIExtractedEntry[]
  bulletSuggestions AIBulletSuggestion[]

  @@map("support_form_uploads")
}

// Stage 2 output: typed entries parsed from the raw extract
model AIExtractedEntry {
  id           String            @id @default(cuid())
  uploadId     String
  upload       SupportFormUpload @relation(fields: [uploadId], references: [id])
  evaluationId String
  section      SectionKey // Classified to CHARACTER | PRESENCE | ... | ACHIEVES
  what         String
  impact       String?
  date         String?
  context      String?
  createdAt    DateTime          @default(now())

  @@map("ai_extracted_entries")
}

// Stage 3 output: ranked bullet candidates per section for rater review
model AIBulletSuggestion {
  id             String             @id @default(cuid())
  evaluationId   String
  evaluation     Evaluation         @relation(fields: [evaluationId], references: [id])
  uploadId       String?
  upload         SupportFormUpload? @relation(fields: [uploadId], references: [id])
  sectionKey     SectionKey
  text           String
  confidence     AIBulletConfidence @default(MEDIUM)
  rank           Int // 1 = best candidate
  status         AIBulletStatus     @default(PENDING_REVIEW)
  editedText     String? // Populated if rater edits before accepting
  reviewedById   String?
  reviewedAt     DateTime?
  sourceEntryIds String[] // AIExtractedEntry OR SupportFormEntry IDs that contributed

  // Immutable snapshot of the source text (entry rawText + artifact captions)
  // at generation time (MVP audit 5.1/5.9). Source entries can be edited or
  // deleted later — this preserves "what was actually said" for provenance
  // and PDF/history purposes regardless of later edits.
  sourceSnapshot Json?
  // e.g. [{ "entryId": "...", "rawText": "...", "artifactCaptions": ["..."] }]

  // Deterministic unsupported-fact warnings computed at generation time
  // (MVP audit 5.10) — numbers/dates/schools/awards in `text` not found in
  // `sourceSnapshot`. Advisory only, never auto-blocking.
  unsupportedClaims Json?
  // e.g. [{ "claimText": "180 hours", "claimType": "NUMBER", "reason": "..." }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_bullet_suggestions")
}

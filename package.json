{
  "name": "ees2-backend",
  "version": "0.1.0",
  "private": true,
  "description": "EES 2.0 backend — Express + TypeScript API (Prisma, Supabase auth, OpenAI, PDF)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch mock-server.ts",
    "dev:real": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "seed:dashboard": "tsx scripts/seed-dashboard-analytics-data.ts",
    "seed:access-assistance": "tsx scripts/seed-access-assistance-data.ts",
    "seed:goal-additions": "tsx scripts/seed-goal-additions-test-data.ts",
    "cleanup:goal-additions": "tsx scripts/cleanup-goal-additions-test-data.ts",
    "test:access-assistance": "tsx scripts/test-access-assistance.ts",
    "ingest:regulations": "tsx src/lib/regulations/ingest.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@react-pdf/renderer": "^4.1.5",
    "@supabase/supabase-js": "^2.47.10",
    "@types/multer": "^2.1.0",
    "@types/pdf-parse": "^1.1.5",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "openai": "^4.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "eslint": "^9.17.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
